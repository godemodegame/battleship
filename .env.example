# Privy application id (GAME-201, GAME-202).
#
# Create separate Privy apps for development and staging at
# https://dashboard.privy.io. For each app:
#   - enable "Wallet" as the only login method;
#   - disable embedded wallet creation;
#   - set the default chain and supported chains to Arbitrum Sepolia (421614);
#   - show EVM wallets only (hide Solana/other non-EVM families).
#
# Leave this unset to run the app and test suite without Privy: practice mode
# stays fully playable, and on-chain routes show a "not configured" wallet
# state instead of the connect UI.
VITE_PRIVY_APP_ID=

# Active deployment id used to resolve /match/:deploymentId/:matchId when a
# deploymentId is not present in the URL (see docs/deployment-plan.md).
# VITE_ACTIVE_DEPLOYMENT_ID=arb-sepolia-v1
