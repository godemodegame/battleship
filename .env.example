# Phase 2 — Privy & Arbitrum Sepolia wallet configuration.
# Copy to `.env.local` and fill in. `.env*` is gitignored; never commit secrets.

# Privy application id (from the Privy dashboard). When unset, the app runs in
# local-practice-only mode: on-chain routes show a "wallet not configured"
# message and the bundle still builds.
VITE_PRIVY_APP_ID=

# Optional Arbitrum Sepolia RPC override. Falls back to the public endpoint
# (https://sepolia-rollup.arbitrum.io/rpc) when blank. Use a dedicated provider
# with monitoring/rate limits for any shared or public deployment.
VITE_ARBITRUM_SEPOLIA_RPC_URL=

# Active deployment id for the versioned /match route. Defaults to
# arb-sepolia-staging-v3 (the live staging contract).
VITE_ACTIVE_DEPLOYMENT_ID=

# Optional release assertion. When set, `npm run verify:release` requires this
# address to match the active committed deployment record exactly.
VITE_BATTLESHIP_CONTRACT_ADDRESS=
